{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "mergeConfidence:all-badges",
    "config:best-practices"
  ],
  "customManagers": [
    {
      "customType": "jsonata",
      "managerFilePatterns": [
        "/^nvim-pack-lock\\.json$/"
      ],
      "matchStrings": [
        'plugins.$each(function($v, $k) { \
          { \
            "depName": $k, \
            "packageName": $v.src, \
            "currentDigest": $v.rev, \
            "currentValue": $v.version ? $replace($v.version, "\'", "") : "main", \
            "datasource": "git-ref", \
            "versioning": "exact" \
          } \
        })'
      ]
    }
  ]
}

