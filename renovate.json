{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices"
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^nvim-pack-lock\\.json$"
      ],
      "matchStrings": [
        "\"(?<depName>[^\"]+)\": \\{[^{}]*?\"rev\": \"(?<currentDigest>[^\"]+)\"[^{}]*?\"src\": \"https?://(?:www\\.)?github\\.com/(?<packageName>[^/\"\\s]+/[^/\"\\s]+?)(?:\\.git)?\"[^{}]*?\"version\": \"(?<currentValue>[^\"]+)\""
      ],
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^nvim-pack-lock\\.json$"
      ],
      "matchStrings": [
        "\"(?<depName>[^\"]+)\": \\{[^{}]*?\"rev\": \"(?<currentValue>[^\"]+)\"[^{}]*?\"src\": \"https?://(?:www\\.)?github\\.com/(?<packageName>[^/\"\\s]+/[^/\"\\s]+?)(?:\\.git)?\"\\s+\\}"
      ],
      "datasourceTemplate": "github-commits"
    }
  ],
  "packageRules": [
    {
      "matchFileNames": [
        "nvim-pack-lock.json"
      ],
      "groupName": "neovim-plugins",
      "schedule": [
        "at any time"
      ]
    }
  ]
}

